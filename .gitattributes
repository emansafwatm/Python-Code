# Automatically detect and normalize text files
* text=auto

# Source code, notebooks, data, and documentation
*.py text eol=lf
*.ipynb text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.csv text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sh text eol=lf

# Windows command files
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.pdf binary
*.zip binary
*.pt binary
*.pth binary
*.ckpt binary
*.h5 binary
*.keras binary
*.onnx binary
*.safetensors binary